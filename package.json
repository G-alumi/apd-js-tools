{
  "name": "apd-js-tools",
  "version": "1.0.5",
  "description": "APD (AzPainter v1) file parser",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "apd-js-tools": "./dist/cli.js"
  },
  "scripts": {
    "prepare": "node -e \"const{execSync}=require('child_process'),fs=require('fs');try{execSync('node ./node_modules/typescript/bin/tsc && node ./node_modules/tsc-alias/dist/bin/index.js',{stdio:'inherit',shell:true})}catch(e){if(!fs.existsSync('./dist/cli.js')){console.error(e.message);process.exit(1)}}\"",
    "build": "tsc && tsc-alias",
    "dev": "ts-node --esm src/cli.ts"
  },
  "keywords": [],
  "author": "G-alumi",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/sharp": "^0.31.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  }
}
